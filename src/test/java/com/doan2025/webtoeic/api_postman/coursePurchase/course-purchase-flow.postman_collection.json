    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login Student",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('HTTP 200', function () {",
                                    "  pm.response.to.have.status(200);",
                                    "});",
                                    "const json = pm.response.json();",
                                    "pm.test('Response code is 200', function () {",
                                    "  pm.expect(json.code).to.eql(200);",
                                    "});",
                                    "if (json.data && json.data.token) {",
                                    "  pm.collectionVariables.set('accessToken', json.data.token);",
                                    "  pm.environment.set('accessToken', json.data.token);",
                                    "}",
                                    "pm.test('Authentication succeeded', function () {",
                                    "  pm.expect(json.data.authenticated).to.eql(true);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Authenticates a student account and persists the JWT token into the collection and environment variables."
